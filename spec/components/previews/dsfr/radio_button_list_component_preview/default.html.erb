<style>
  .preview-section { border-bottom: 1px solid #ddd; padding: 2rem 0; }
  .preview-section:last-child { border-bottom: none; }
  .preview-label { font-size: 0.75rem; font-weight: bold; text-transform: uppercase; color: #666; margin-bottom: 1rem; letter-spacing: 0.05em; }
</style>

<div class="fr-container fr-py-4w">

  <%# ── 1. Défaut ─────────────────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">Défaut — empilé</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :nature,
        buttons: [
          { label: "Option A", value: "a" },
          { label: "Option B", value: "b" }
        ]
      ) do %>
        Choisissez une option
      <% end %>
    <% end %>
  </div>

  <%# ── 2. Inline ──────────────────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">Inline</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :gender,
        buttons: [
          { label: "Madame", value: "Mme" },
          { label: "Monsieur", value: "M." }
        ],
        inline: true
      ) do %>
        Civilité
      <% end %>
    <% end %>
  </div>

  <%# ── 3. Avec erreur ─────────────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">État erreur</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :nature,
        buttons: [
          { label: "Option A", value: "a" },
          { label: "Option B", value: "b" }
        ],
        error: "Veuillez sélectionner une option"
      ) do %>
        Choisissez une option
      <% end %>
    <% end %>
  </div>

  <%# ── 4. Avec hints ──────────────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">Avec hints</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :access,
        buttons: [
          { label: "Lecture seule", value: "read", hint: "Récupérer des dossiers et leurs pièces jointes" },
          { label: "Lecture et écriture", value: "read_write", hint: "Changer le statut des dossiers, écrire des messages" }
        ]
      ) do %>
        Niveau d'accès
      <% end %>
    <% end %>
  </div>

  <%# ── 5. Avec tooltip ────────────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">Avec tooltip</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :champ,
        buttons: [
          { label: "Département", value: "departement", hint: "[Liste déroulante]", tooltip: "Ain, Aisne, Allier, Alpes-de-Haute-Provence…" },
          { label: "Région", value: "region", hint: "[Liste déroulante]", tooltip: "Auvergne-Rhône-Alpes, Bourgogne-Franche-Comté…" }
        ]
      ) do %>
        Champ de routage
      <% end %>
    <% end %>
  </div>

  <%# ── 6. Option désactivée ───────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">Option désactivée</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :lifetime,
        buttons: [
          { label: "1 semaine", value: "one_week" },
          { label: "Personnalisée", value: "custom" },
          { label: "Infinie", value: "infinite", disabled: true, hint: "Nécessite un filtrage réseau activé" }
        ]
      ) do %>
        Durée de vie du jeton
      <% end %>
    <% end %>
  </div>

  <%# ── 7. Sans regular_legend ────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">regular_legend: false (intégration dans une liste de champs)</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :notification,
        buttons: [
          { label: "Toujours", value: "all" },
          { label: "Jamais", value: "none" }
        ],
        inline: true,
        regular_legend: false
      ) do %>
        Notifications sur dépôt
      <% end %>
    <% end %>
  </div>

  <%# ── 8. Erreur + inline ─────────────────────────────────────── %>
  <div class="preview-section">
    <p class="preview-label">Erreur + inline</p>
    <%= form_with url: "#" do |f| %>
      <%= render Dsfr::RadioButtonListComponent.new(
        form: f,
        target: :gender,
        buttons: [
          { label: "Madame", value: "Mme", required: true },
          { label: "Monsieur", value: "M.", required: true }
        ],
        inline: true,
        error: "La civilité est obligatoire"
      ) do %>
        Civilité
      <% end %>
    <% end %>
  </div>
</div>

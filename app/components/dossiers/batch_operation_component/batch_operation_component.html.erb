<div class="fr-background-alt--blue-france fr-p-2w fr-mb-n2w">
  <div class="batch-operation flex align-center">
    <span class="fr-mr-1w" data-batch-operation-target="checkboxCount">
      0 dossier sélectionné
    </span>

    <% if available_operations[:options].count.between?(1,3) %>
      <%= form_for(BatchOperation.new, url: instructeur_batch_operations_path(procedure_id: procedure.id), method: :post, html: { class: 'form', id: dom_id(BatchOperation.new) }, data: { turbo: true, turbo_confirm: t('.operations.confirm') }) do |form| %>
        <% available_operations[:options].each do |opt| %>
          <%= render Dossiers::BatchOperationInlineButtonsComponent.new(opt:, icons:, form:) %>
        <% end %>
      <% end %>
    <% else %>
      <%= form_for(BatchOperation.new, url: instructeur_batch_operations_path(procedure_id: procedure.id), method: :post, html: { class: 'form flex', id: dom_id(BatchOperation.new) }, data: { turbo: true, turbo_confirm: t('.operations.confirm') }) do |form| %>
        <% available_operations[:options][0,2].each do |opt| %>
          <%= render Dossiers::BatchOperationInlineButtonsComponent.new(opt:, icons:, form:) %>
        <% end %>

        <div class="dropdown" data-controller="menu-button" data-popover="true">
          <button
            class="fr-btn fr-btn--sm fr-btn--secondary fr-ml-1w dropdown-button"
            id="batch_operation_others"
            disabled
            data-menu-button-target="button"
            data-batch-operation-target="dropdown"
          >
            <%= t('.operations.other') %>
            <span class="fr-ml-2v" aria-hidden="true"></span>
          </button>

          <div
            class="dropdown-content fade-in-down"
            id="state-menu"
            data-menu-button-target="menu"
            aria-labelledby="batch_operation_others"
          >
            <ul class="dropdown-items">
              <% available_operations[:options][2, available_operations[:options].count].each do |opt| %>
                <% unless expert_review_disallowed?(opt[:operation]) %>
                  <li>
                    <%= form.button opt[:label], class: 'dropdown-items-link', disabled: true, name: "#{form.object_name}[operation]", value: opt[:operation], data: { operation: opt[:operation]}.merge(opt[:modal_data].to_h), aria: { controls: opt[:aria].present? ? opt[:aria] : nil} do %>
                      <span class="<%= icons[opt[:operation].to_sym] %>"></span>

                      <div class="dropdown-description">
                        <h4><%= opt[:label] %></h4>
                      </div>
                    <% end %>
                  </li>
                <% end %>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
      <dialog
        class="fr-modal"
        id="modal-avis-batch"
        aria-labelledby="fr-modal-title-avis-batch"
        role="dialog"
      >
        <div class="fr-container fr-container--fluid fr-container-md">
          <div class="fr-grid-row fr-grid-row--center">
            <div class="fr-col-12 fr-col-md-10 fr-col-lg-8">
              <div class="fr-modal__body">
                <div class="fr-modal__header">
                  <button
                    class="fr-btn--close fr-btn"
                    aria-controls="modal-avis-batch"
                    title="<%= t('utils.modal_close_alt') %>"
                  >
                    <%= t('utils.modal_close') %>
                  </button>
                </div>

                <div class="fr-modal__content">
                  <h1 class="fr-modal__title" id="fr-modal-title-avis-batch">
                    <span class="fr-icon-arrow-right-line fr-icon--lg"></span>
                    Demander un avis externe
                  </h1>

                  <%= render partial: "shared/avis/form_wrapper", locals: {url: create_batch_avis_instructeur_batch_operations_path(procedure_id: procedure.id), linked_dossiers: nil, must_be_confidentiel: false, avis: Avis.new, batch_action: true, procedure: procedure, dossier_ids: @ids } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </dialog>
    <% end %>

    <dialog
      class="fr-modal"
      id="modal-commentaire-batch"
      aria-labelledby="fr-modal-title-commentaire-batch"
      role="dialog"
    >
      <div class="fr-container fr-container--fluid fr-container-md">
        <div class="fr-grid-row fr-grid-row--center">
          <div class="fr-col-12 fr-col-md-10 fr-col-lg-8">
            <div class="fr-modal__body">
              <div class="fr-modal__header">
                <button
                  class="fr-btn--close fr-btn"
                  aria-controls="modal-commentaire-batch"
                  title="<%= t('utils.modal_close_alt') %>"
                >
                  <%= t('utils.modal_close') %>
                </button>
              </div>

              <div class="fr-modal__content">
                <h1 class="fr-modal__title" id="modal-title-commentaire-batch">
                  <span class="fr-icon-arrow-right-line fr-icon--lg"></span>

                  <span
                    class="hidden"
                    data-batch-operation-target="commentaireTitleSingular"
                  >
                    <%= t('.commentaire_modal.title_singular') %>
                  </span>

                  <span
                    class="hidden"
                    data-batch-operation-target="commentaireTitlePlural"
                  >
                    <%= t('.commentaire_modal.title_plural', count: '__COUNT__') %>
                  </span>
                </h1>

                <div data-batch-operation-target="commentaireFormContainer">
                  <%= render partial: "instructeurs/batch_operations/commentaire_form", locals: {url: create_batch_commentaire_instructeur_batch_operations_path(procedure_id: procedure.id), commentaire: Commentaire.new, procedure: procedure, dossier_ids: @ids } %>
                </div>

                <div
                  class="hidden"
                  data-batch-operation-target="commentaireWarning"
                >
                  <div class="fr-alert fr-alert--warning">
                    <%= t('.commentaire_warning_html', limit: BatchOperation::BATCH_SELECTION_LIMIT) %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </dialog>
  </div>
</div>

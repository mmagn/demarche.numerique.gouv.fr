<div class="fr-alert fr-alert--error fr-mb-3w" role="alert">
  <% if dedup_errors.size > 0 %>
    <h2
      class="fr-alert__title"
      id="sumup-errors"
      data-controller="autofocus"
      tabindex="-1"
    >
      <%= t('.sumup_html.title', count: dedup_errors.size) %>
    </h2>
    <p><%= t('.sumup_html.content', count: dedup_errors.size) %></p>
    <%= render ExpandableErrorList.new(errors: dedup_errors) %>
  <% end %>
</div>

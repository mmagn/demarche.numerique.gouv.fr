.direct-upload.fr-upload-group.fr-mr-2w.fr-mt-3w.fr-mb-0.fr-px-3v.fr-py-1w{ id: "direct-upload-#{id}", class: ('direct-upload--simulated' if simulated), data: { direct_upload_id: id } }
  .direct-upload__error.fr-messages-group.hidden
    %p.fr-message.fr-message--error.fr-mt-0.direct-upload__error-message
  .direct-upload__progress{ role: "progressbar", 'aria-label': t(".loading"), tabindex: "0", 'aria-valuemin': "0", 'aria-valuemax': "100", style: (simulated ? nil : "width: 0%") }
  %span.fr-label.direct-upload__filename
    = content
  .direct-upload__retry.hidden
    %button.fr-btn.fr-btn--sm.fr-btn--secondary{ type: 'button' }
      = t(".retry")

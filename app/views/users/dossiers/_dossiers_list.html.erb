<% if dossiers.present? %>
  <h2 class="fr-h6 fr-my-2w"><%= page_entries_info dossiers %></h2>
  <% dossiers.each do |dossier| %>
    <div class="card" id="dossier_<%= dossier.id %>">
      <div class="flex justify-between">
        <div>
          <h3 class="card-title">
            <% if ["dossiers-transferes", "dossiers-supprimes"].exclude?(@statut) %>
              <%= link_to(url_for_dossier(dossier)) do %>
                <%= dossier.procedure.libelle %>

                <span class="fr-sr-only">
                  <%= t('views.users.dossiers.dossiers_list.n_dossier') %>
                  <%= number_with_html_delimiter(dossier.id) %>
                </span>
              <% end %>
            <% else %>
              <%= dossier.procedure.libelle %>
            <% end %>
          </h3>

          <div class="badge_info fr-mb-1w fr-hidden-md">
            <p class="fr-mb-0">
              <%= t('views.users.dossiers.dossiers_list.n_dossier') %>
              <%= number_with_html_delimiter(dossier.id) %>
            </p>

            <%= status_badge_user(dossier, 'fr-mb-1w') %>

            <% if dossier.pending_correction? %>
              <br>
              <%= pending_correction_badge(:for_user) %>
            <% end %>

            <% if dossier.pending_response? %>
              <br>
              <%= pending_response_badge(:for_user) %>
            <% end %>
          </div>

          <p class="fr-icon--sm fr-icon-user-line">
            <span class="fr-sr-only">
              <%= t('views.shared.dossiers.demande.requester_identity') %>
            </span>

            <%= demandeur_dossier(dossier) %>
          </p>

          <% if dossier.hidden_by_expired? %>
            <p class="fr-icon--sm fr-icon-delete-line">
              <%= t('views.users.dossiers.dossiers_list.deleted_by_automatic', date: l(dossier.hidden_by_expired_at.to_date, format: :long)) %>
            </p>
          <% elsif dossier.hidden_by_user? %>
            <p class="fr-icon--sm fr-icon-delete-line">
              <%= t('views.users.dossiers.dossiers_list.deleted_by_user', date: l(dossier.hidden_by_user_at.to_date, format: :long)) %>
            </p>
          <% else %>
            <p class="fr-icon--sm fr-icon-edit-box-line">
              <% if dossier.depose_at.present? %>
                <span>
                  <%= t('views.users.dossiers.dossiers_list.depose_at', date: l(dossier.depose_at.to_date, format: :long)) %>
                </span>
              <% else %>
                <span>
                  <%= t('views.users.dossiers.dossiers_list.created_at', date: l(dossier.created_at.to_date, format: :long)) %>
                </span>
                <% if dossier.created_at != dossier.updated_at %>
                  <%= t('views.users.dossiers.dossiers_list.updated_at', date: l(dossier.updated_at, format: :long_with_time)) %>
                <% end %>
              <% end %>
            </p>
            <% if dossier.invites.present? %>
              <p class="fr-icon--sm fr-icon-shield-line">
                <%= t('views.users.dossiers.dossiers_list.shared_with', owner: dossier.user_email_for(:display)) %>
                <%= dossier.invites.map(&:email).join(', ') %>
              </p>
            <% end %>
          <% end %>
        </div>

        <div class="badge_info text-right fr-hidden unhidden-md">
          <p class="fr-mb-0">
            <%= t('views.users.dossiers.dossiers_list.n_dossier') %>
            <%= number_with_html_delimiter(dossier.id) %>
          </p>

          <%= status_badge_user(dossier, 'fr-mb-1w') %>

          <% if dossier.pending_correction? %>
            <br>
            <%= pending_correction_badge(:for_user) %>
          <% end %>

          <% if dossier.pending_response? %>
            <br>
            <%= pending_response_badge(:for_user) %>
          <% end %>
        </div>
      </div>

      <% if dossier.procedure.close? %>
        <%= render Dsfr::AlertComponent.new(state: :info, size: :sm, extra_class_names: "fr-mb-2w") do |c| %>
          <% c.with_body do %>
            <% if dossier.brouillon? && can_recreate_a_dossier_from_a_procedure?(dossier.procedure) %>
              <%= t('views.users.dossiers.dossiers_list.procedure_closed.brouillon.internal_procedure_html', link: link_to(t('views.users.dossiers.dossiers_list.procedure_closed.procedure'), commencer_path(dossier.procedure.replaced_by_procedure.path), **external_link_attributes, class: 'fr-link', title: new_tab_suffix(t('views.users.dossiers.dossiers_list.procedure_closed.title_new_procedure'))).html_safe) %>
            <% elsif dossier.brouillon? %>
              <%= t('views.users.dossiers.dossiers_list.procedure_closed.brouillon.other_html', link: link_to(t('views.users.dossiers.dossiers_list.procedure_closed.more_details'), closing_details_path(dossier.procedure.path), **external_link_attributes, class: 'fr-link', title: new_tab_suffix(t('views.users.dossiers.dossiers_list.procedure_closed.title_closing_details'))).html_safe) %>
            <% elsif dossier.en_construction_ou_instruction? && can_recreate_a_dossier_from_a_procedure?(dossier.procedure) %>
              <%= t('views.users.dossiers.dossiers_list.procedure_closed.en_cours.internal_procedure_html', link: link_to(t('views.users.dossiers.dossiers_list.procedure_closed.procedure'), commencer_path(dossier.procedure.replaced_by_procedure.path), **external_link_attributes, class: 'fr-link', title: new_tab_suffix(t('views.users.dossiers.dossiers_list.procedure_closed.title_new_procedure'))).html_safe) %>
            <% elsif dossier.en_construction_ou_instruction? && !dossier.procedure.replaced_by_procedure.present? %>
              <%= t('views.users.dossiers.dossiers_list.procedure_closed.en_cours.other_html', link: link_to(t('views.users.dossiers.dossiers_list.procedure_closed.more_details'), closing_details_path(dossier.procedure.path), **external_link_attributes, class: 'fr-link', title: new_tab_suffix(t('views.users.dossiers.dossiers_list.procedure_closed.title_closing_details'))).html_safe) %>
            <% elsif dossier.termine? && can_recreate_a_dossier_from_a_procedure?(dossier.procedure) %>
              <%= t('views.users.dossiers.dossiers_list.procedure_closed.termine.internal_procedure_html', link: link_to(t('views.users.dossiers.dossiers_list.procedure_closed.this_procedure'), commencer_path(dossier.procedure.replaced_by_procedure.path), **external_link_attributes, class: 'fr-link', title: new_tab_suffix(t('views.users.dossiers.dossiers_list.procedure_closed.title_new_procedure'))).html_safe) %>
            <% elsif dossier.termine? %>
              <%= t('views.users.dossiers.dossiers_list.procedure_closed.termine.other_html', link: link_to(t('views.users.dossiers.dossiers_list.procedure_closed.more_details'), closing_details_path(dossier.procedure.path), **external_link_attributes, class: 'fr-link', title: new_tab_suffix(t('views.users.dossiers.dossiers_list.procedure_closed.title_closing_details'))).html_safe) %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>

      <% if dossier.pending_correction? %>
        <%= render Dsfr::AlertComponent.new(state: :warning, size: :sm, extra_class_names: "fr-mb-2w") do |c| %>
          <% c.with_body do %>
            <%= t('views.users.dossiers.dossiers_list.pending_correction_html', link: messagerie_dossier_path(dossier), id: dossier.id, class: 'fr-link') %>
          <% end %>
        <% end %>
      <% end %>

      <% if dossier.awaiting_response.present? %>
        <%= render Dsfr::AlertComponent.new(state: :warning, size: :sm, extra_class_names: "fr-mb-2w") do |c| %>
          <% c.with_body do %>
            <h4 class="card-title fr-mb-1v">
              <%= t('views.users.dossiers.dossiers_list.pending_response.title') %>
            </h4>

            <p>
              <%= t('views.users.dossiers.dossiers_list.pending_response.message_html', link: messagerie_dossier_path(dossier), id: number_with_html_delimiter(dossier.id)).html_safe %>
            </p>
          <% end %>
        <% end %>
      <% end %>

      <% if dossier.transfer.present? %>
        <% if @statut == "dossiers-transferes" %>
          <%= render Dsfr::AlertComponent.new(state: :info, size: :sm) do |c| %>
            <% c.with_body do %>
              <% if dossier.transfer.from_support? %>
                <%= t('views.users.dossiers.transfers.receiver_demande_en_cours_from_support_html', id: dossier.id, email: dossier.user_email_for(:notification)) %>
              <% else %>
                <%= t('views.users.dossiers.transfers.receiver_demande_en_cours_html', id: dossier.id, email: dossier.user_email_for(:notification)) %>
              <% end %>

              <ul class="fr-links-group fr-links-group--inline">
                <li>
                  <%= link_to t('views.users.dossiers.transfers.accept'), transfer_path(dossier.transfer), class: "fr-link", method: :put %>
                </li>

                <li>
                  <%= link_to t('views.users.dossiers.transfers.reject'), transfer_path(dossier.transfer), class: "fr-link", method: :delete %>
                </li>
              </ul>
            <% end %>
          <% end %>
        <% else %>
          <%= render Dsfr::AlertComponent.new(state: :info, size: :sm, extra_class_names: "fr-pb-1w fr-mb-2w") do |c| %>
            <% c.with_body do %>
              <% if dossier.transfer.from_support? %>
                <%= t('views.users.dossiers.transfers.sender_demande_en_cours_from_support_html', id: dossier.id, email: dossier.transfer.email) %>
              <% else %>
                <%= t('views.users.dossiers.transfers.sender_demande_en_cours_html', id: dossier.id, email: dossier.transfer.email) %>
              <% end %>

              <%= link_to t('views.users.dossiers.transfers.revoke_html'), transfer_path(dossier.transfer), class: 'fr-link', method: :delete %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>

      <% if ["dossiers-transferes", "dossiers-supprimes"].exclude?(@statut) %>
        <div class="flex justify-end no-flex-xs">
          <%= render partial: 'dossier_actions', locals: { dossier: dossier } %>
        </div>
      <% end %>

      <% if @statut == "dossiers-supprimes" && dossier.en_construction? %>
        <%= render Dsfr::AlertComponent.new(state: :info, size: :sm, extra_class_names: "fr-mb-2w") do |c| %>
          <% c.with_body do %>
            <p>
              <%= t('views.users.dossiers.index.administration_no_longer_processes') %>
            </p>
          <% end %>
        <% end %>
      <% end %>

      <% if @statut == "dossiers-supprimes" %>
        <div class="flex justify-end no-flex-xs">
          <% if dossier.hidden_by_reason != 'expired' %>
            <%= link_to restore_dossier_path(dossier.id), method: :patch, class: "fr-btn fr-btn--sm" do %>
              <%= t("views.users.dossiers.dossier_action.restore") %>

              <span class="fr-sr-only">
                <%= t('utils.file') %>
                <%= t('utils.number') %>
                <%= number_with_html_delimiter(dossier.id) %>
              </span>
            <% end %>
          <% else %>
            <% if dossier.expiration_can_be_extended? %>
              <%= button_to users_dossier_repousser_expiration_and_restore_path(dossier), class: 'fr-btn fr-btn--sm' do %>
                <%= t("views.users.dossiers.dossier_action.restore_and_extend_conservation_html", id: dossier.id, duree_conservation_dossiers_dans_ds: dossier.procedure.duree_conservation_dossiers_dans_ds) %>
              <% end %>
            <% else %>
              <div class="flex justify-end no-flex-xs">
                <ul
                  class="
                    fr-btns-group fr-btns-group--inline-md
                    fr-btns-group--icon-left fr-btns-group--sm
                  "
                >
                  <li>
                    <%= render(partial: 'users/dossiers/show/download_dossier', locals: { dossier: dossier }) %>
                  </li>

                  <li>
                    <%= render(partial: 'users/dossiers/show/download_attestation', locals: { dossier: dossier }) %>
                  </li>
                </ul>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
  <%= paginate dossiers, views_prefix: 'shared' %>
<% else %>
  <% if filter.present? && filter.filter_params_count > 0 %>
    <div class="blank-tab">
      <h2 class="empty-text">
        <%= t('views.users.dossiers.dossiers_list.no_result_title') %>
      </h2>

      <p class="empty-text-details">
        <%= t('views.users.dossiers.dossiers_list.no_result_text_with_filter') %>
        <br>
        <%= link_to t('views.users.dossiers.dossiers_list.no_result_reset_filter'), dossiers_path(statut: statut), class: 'fr-btn fr-btn--sm fr-mt-2w' %>
      </p>
    </div>
  <% elsif search %>
    <div class="blank-tab">
      <h2 class="empty-text">
        <%= t('views.users.dossiers.dossiers_list.no_result_title') %>
      </h2>

      <p class="empty-text-details">
        <%= t('views.users.dossiers.dossiers_list.no_result_text_with_search') %>
        <br>
        <%= link_to t('views.users.dossiers.dossiers_list.no_result_reset_search'), dossiers_path(), class: 'fr-btn fr-btn--sm fr-mt-2w' %>
      </p>
    </div>
  <% else %>
    <div class="blank-tab">
      <h2 class="empty-text">
        <%= t('views.users.dossiers.dossiers_list.no_result_title') %>
      </h2>

      <p class="empty-text-details">
        <%= t('views.users.dossiers.dossiers_list.no_result_text_html', app_base: Current.application_base_url) %>
      </p>

      <p>
        <%= link_to t("root.landing.how_to_find_procedure"), t("links.common.faq.comment_trouver_ma_demarche_url"), class: "fr-btn fr-btn--lg fr-mr-1w fr-mb-2w" %>
      </p>
    </div>
  <% end %>
<% end %>

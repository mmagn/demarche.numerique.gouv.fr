- content_for(:title, 'Invitation à donner votre avis')

- content_for(:footer) do
  Merci de ne pas répondre à cet email. Donnez votre avis
  = link_to("sur #{APPLICATION_NAME}", @url)
  ou
  = succeed '.' do
    = mail_to(@claimant_email, "contactez la personne qui vous a invité")

%p
  Bonjour,


%p
  Vous avez été invité par
  %strong= @claimant_email

  - if @multiple
    = "à donner votre avis sur #{@avis.count} dossiers de la démarche :"
    %strong= @avis_unique.procedure.libelle
  - else
    = "à donner votre avis sur le dossier n° #{@avis_unique.dossier.id} de la démarche :"
    %strong= @avis_unique.procedure.libelle

  %p
    = dsfr_button(@call_to_action, @url, :primary)


= render partial: "layouts/mailers/signature"

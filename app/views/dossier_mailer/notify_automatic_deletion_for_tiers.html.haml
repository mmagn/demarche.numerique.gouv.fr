- content_for(:title, "#{@subject}")

%p= t(:hello, scope: [:views, :shared, :greetings])

%p
  = t('.header', count: @hidden_dossiers.size, deletion_date: human_date(@deletion_date.to_date))
  %ul
    - @hidden_dossiers.each do |d|
      %li
        = t('.list', count: @hidden_dossiers.size, dossier_id: d.id, libelle: d.procedure.libelle)
        - if @hidden_dossiers.many?
          = "#{d.mandataire_first_name} #{d.mandataire_last_name} (#{mail_to(d.user_email_for(:notification))})."

%p
  = t('.more_information', count: @hidden_dossiers.size)
  - if @hidden_dossiers.one?
    - d = @hidden_dossiers.first
    = "#{d.mandataire_first_name} #{d.mandataire_last_name} (#{mail_to(d.user_email_for(:notification))})."

= render partial: "layouts/mailers/signature"

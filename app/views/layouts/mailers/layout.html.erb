<!doctype html>

<html
  xmlns="http://www.w3.org/1999/xhtml"
  xmlns:v="urn:schemas-microsoft-com:vml"
  xmlns:o="urn:schemas-microsoft-com:office:office"
>
  <head><%= render "layouts/mailers/dsfr_head" %></head>

  <body style="font-family: 'Marianne', Arial, Helvetica, sans-serif;">
    <%# Outer wrapper: full-width white background %>
    <table
      style="min-width:100%!important; width:100%;"
      width="100%"
      cellspacing="0"
      cellpadding="0"
      role="presentation"
      border="0"
      bgcolor="#ffffff"
      class="wlkm-mw darkmode"
    >
      <tr>
        <td align="center" class="darkmode">
          <%= render "layouts/mailers/dsfr_header" %>

          <%# Content area: 600px centered with side borders %>
          <table
            style="min-width:620px;margin:0 auto; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt; background:linear-gradient(90deg, rgba(255,255,255,1) 0%, rgba(234,234,234,1) 5%, rgba(234,234,234,1) 95%, rgba(255,255,255,1) 100%);"
            width="620"
            cellspacing="0"
            cellpadding="0"
            role="presentation"
            border="0"
            align="center"
            class="wlkm-mw darkmode"
          >
            <tr>
              <td align="center">
                <table
                  style="min-width:600px;margin:0 auto; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt;width:600px;border-left:1px #e5e5e5 solid; border-right:1px #e5e5e5 solid; border-bottom:1px #e5e5e5 solid;"
                  class="wlkm-mw darkmode"
                  width="600"
                  cellspacing="0"
                  cellpadding="0"
                  role="presentation"
                  border="0"
                  bgcolor="#ffffff"
                  align="center"
                >
                  <tr>
                    <td>
                      <table
                        style="margin:0 auto; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt;width:496px;"
                        class="wlkm-cl darkmode"
                        width="496"
                        cellspacing="0"
                        cellpadding="0"
                        role="presentation"
                        border="0"
                        bgcolor="#ffffff"
                        align="center"
                      >
                        <%# Optional title %>
                        <% if content_for?(:title) %>
                          <tr>
                            <td
                              class="darkmode"
                              style="padding:20px 10px; line-height:32px; font-size:24px; color:#161616; font-family:'Marianne', Arial, Helvetica, sans-serif;"
                            >
                              <strong><%= yield(:title) %></strong>
                            </td>
                          </tr>
                        <% end %>

                        <%# Main content %>
                        <tr>
                          <td
                            class="darkmode"
                            style="padding:10px 10px; line-height:24px; font-size:14px; color:#161616; font-family:'Marianne', Arial, Helvetica, sans-serif;"
                          >
                            <%= yield %>
                          </td>
                        </tr>

                        <%# Business footer (signature, service info) %>
                        <% if content_for?(:footer) %>
                          <tr>
                            <td
                              class="darkmode-1"
                              style="padding:10px 10px 20px 10px; line-height:22px; font-size:12px; color:#6b6b6b; font-family:'Marianne', Arial, Helvetica, sans-serif;"
                            >
                              <p style="font-size:13px;">—</p>
                              <%= yield(:footer) %>
                            </td>
                          </tr>
                        <% end %>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>

          <%= render "layouts/mailers/dsfr_footer" %>
        </td>
      </tr>
    </table>
  </body>
</html>
